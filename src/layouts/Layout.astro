---
import '../styles/styles.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  layoutMode?: 'dashboard' | 'blog';
  backLink?: string;
  backText?: string;
}

const {
  title,
  description,
  ogImage = '/assets/og-preview.png',
  layoutMode = 'dashboard',
  backLink = '/index.html#blog',
  backText = 'Return to Console',
} = Astro.props;

// Schema.org structured data
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Haranadh Gavara",
  "url": "https://haranadh.com",
  "sameAs": [
    "https://www.linkedin.com/in/haranadhgavara/"
  ],
  "jobTitle": "Enterprise Architect & AI Systems Leader",
  "worksFor": {
    "@type": "Organization",
    "name": "Datavid"
  },
  "knowsAbout": [
    "Retrieval-Augmented Generation (RAG)",
    "Entropy RAG",
    "MaxEntRAG",
    "Knowledge Graphs",
    "GraphRAG",
    "Gaussian Processes",
    "Gaussian Process Regression",
    "Enterprise AI",
    "Enterprise Architecture",
    "AI Systems",
    "Data Products",
    "AI Governance"
  ],
  "alumniOf": [
    {
      "@type": "EducationalOrganization",
      "name": "Indian Institute of Technology, Madras"
    },
    {
      "@type": "EducationalOrganization",
      "name": "Indian Institute of Management, Tiruchirappalli"
    }
  ],
  "description": description
};

// Standardized canonical URL — strips .html extension to match sitemap clean URLs
// This prevents "Duplicate without user-selected canonical" warnings in Search Console
const canonicalURL = new URL(Astro.url.pathname, 'https://haranadh.com').href
  .replace(/\/index\.html$/, '/')
  .replace(/\.html$/, '');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- Primary SEO Meta Tags -->
  <title>{title}</title>
  <meta name="title" content={title}>
  <meta name="description" content={description}>
  <meta name="author" content="Haranadh Gavara">
  <meta name="robots" content="index, follow">

  <!-- Canonical Link -->
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph / Facebook / LinkedIn -->
  <meta property="og:type" content={layoutMode === 'dashboard' ? 'website' : 'article'}>
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={new URL(ogImage, Astro.site || Astro.url).href}>
  <meta property="og:site_name" content="Haranadh Gavara Portfolio & Blog">
  <meta property="og:locale" content="en_US">

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content={canonicalURL}>
  <meta property="twitter:title" content={title}>
  <meta property="twitter:description" content={description}>
  <meta property="twitter:image" content={new URL(ogImage, Astro.site || Astro.url).href}>
  
  <!-- JSON-LD Structured Data Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' stop-color='%230D7A5F'/%3E%3Cstop offset='100%25' stop-color='%2325545E'/%3E%3C/linearGradient%3E%3C/defs%3E%3Crect width='100' height='100' rx='30' fill='url(%23g)'/%3E%3Cpath d='M35 25 v50 M65 25 v50 M35 50 h30' stroke='%23FFFFFF' stroke-width='14' stroke-linecap='round'/%3E%3C/svg%3E">
  
  <!-- Vector Icons (FontAwesome) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  
  {layoutMode === 'dashboard' ? (
    <div class="dashboard-wrapper">
      <!-- Console Sidebar (Dashboard Left Panel) -->
      <aside class="console-sidebar">
        <div class="sidebar-brand-wrapper">
          <a href="/#home" class="logo-lockup" id="nav-logo">
            <div class="logo-icon">H</div>
            <div class="logo-identity">
              <span class="logo-name">Haranadh Gavara</span>
              <span class="logo-subtitle">AI Systems Leader & EA</span>
            </div>
          </a>
          <button class="mobile-menu-toggle" id="mobile-menu-btn" aria-label="Toggle Menu">
            <i class="fas fa-bars"></i>
          </button>
        </div>
        
        <nav class="console-nav">
          <ul class="nav-links">
            <li><a href="/#home" class="active"><i class="fas fa-terminal"></i> Home Console</a></li>
            <li><a href="/#architecture"><i class="fas fa-network-wired"></i> Architectures</a></li>
            <li><a href="/#products"><i class="fas fa-cubes"></i> Products</a></li>
            <li><a href="/#publications"><i class="fas fa-file-alt"></i> Research</a></li>
            <li><a href="/blogs.html"><i class="fas fa-edit"></i> Blog</a></li>
            <li><a href="/management.html"><i class="fas fa-briefcase"></i> Leadership</a></li>
            <li><a href="/#about"><i class="fas fa-user-tie"></i> Biography</a></li>
            <li><a href="/#contact"><i class="fas fa-envelope"></i> Connect</a></li>
          </ul>
        </nav>
        
        <div class="sidebar-social">
          <a href="https://www.linkedin.com/in/haranadhgavara/" target="_blank" rel="noopener noreferrer"><i class="fab fa-linkedin-in"></i></a>
        </div>
      </aside>

      <!-- MAIN CONSOLE PANEL -->
      <main class="console-main">
        <slot />
      </main>
    </div>
  ) : (
    <div class="blogs-archive-wrapper">
      <div class="container">
        <!-- Premium Glassmorphic Top Nav -->
        <nav class="blogs-nav glass-card">
          <a href="/" class="logo-lockup" style="max-width: fit-content;">
            <div class="logo-icon">H</div>
            <div class="logo-identity">
              <span class="logo-name">Haranadh Gavara</span>
              <span class="logo-subtitle">AI Systems Leader & EA</span>
            </div>
          </a>
          <a href={backLink} class="back-btn">
            <i class="fas fa-arrow-left"></i> {backText}
          </a>
        </nav>

        <slot />
      </div>
    </div>
  )}

  <script>
    import '../scripts/app.js';
    import '../scripts/canvas.js';
  </script>
</body>
</html>
