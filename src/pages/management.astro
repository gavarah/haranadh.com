---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Leadership & Management Blog | Haranadh Gavara" 
  description="Operational perspectives on engineering management, startup scaling, and technical debt by Haranadh Gavara."
  layoutMode="blog"
  backLink="/"
  backText="Return to Home"
>
  <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; text-align: center;">
    <div class="glass-card" style="padding: 48px; max-width: 600px; background: var(--bg-secondary); border: 1px dashed var(--accent-indigo); margin-top: 40px; width: 100%;">
      <div style="font-size: 2.5rem; color: var(--accent-indigo); margin-bottom: 20px;">
        <i class="fas fa-briefcase"></i>
      </div>
      <span class="section-label" style="margin-bottom: 8px;">Leadership &amp; Management</span>
      <h1 style="font-size: 2rem; font-weight: 800; color: var(--text-primary); margin-bottom: 16px; letter-spacing: -0.5px;">Coming Soon</h1>
      <p style="font-size: 1rem; color: var(--text-secondary); line-height: 1.6; margin-bottom: 28px;">
        Operational perspectives on team design, scaling software squads, engineering culture, and business outcomes.
      </p>
      <div style="background: rgba(13, 122, 95, 0.03); padding: 18px 24px; border-radius: var(--border-radius-sm); border: 1px solid var(--border-color); font-size: 0.9rem; color: var(--text-secondary); font-weight: 600; letter-spacing: 0.5px;">
        Releasing with open-source launch
      </div>
    </div>
  </div>
</Layout>
