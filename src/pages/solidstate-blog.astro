---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('solidstate');
const sortedPosts = posts.sort((a, b) => a.data.postNumber - b.data.postNumber);
---

<Layout 
  title="SolidState Product Blog | Haranadh Gavara | Bounded AI Agent Runtimes" 
  description="Technical blog series on building predictable, state-oriented runtime environments for enterprise AI agents. Learn about ReAct loops, dynamic tool registries, and policy interceptors."
  layoutMode="blog"
  backLink="/#products"
  backText="Return to Products"
>
  <!-- Main Product Essay Area -->
  <div class="blogs-content-area">
    <div class="series-container">
      
      <!-- Syllabus Sidebar -->
      <aside class="series-aside glass-card" style="padding: 24px; background: var(--bg-secondary); border-radius: var(--border-radius-sm); border: 1px solid var(--border-color);">
        <h3 style="font-size: 0.9rem; font-weight: 700; color: var(--accent-indigo); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">Syllabus</h3>
        <nav style="display: flex; flex-direction: column; gap: 8px;">
          {sortedPosts.map((post, index) => {
            let shortTitle = post.data.tag;
            if (post.data.postNumber === 1) shortTitle = "Minimal Agent Runtime";
            if (post.data.postNumber === 2) shortTitle = "Dynamic Tool Registries";
            if (post.data.postNumber === 3) shortTitle = "Policy & Intercepts";
            return (
              <a href={`#post-${post.data.postNumber}`} class={`sidebar-item ${index === 0 ? 'active' : ''}`} id={`nav-post-${post.data.postNumber}`}>
                <span style="font-size: 0.72rem; color: var(--text-muted); display: block; font-weight: 500;">Post {post.data.postNumber} • {post.data.date.split(',')[0]}</span>
                {post.data.postNumber}. {shortTitle}
              </a>
            );
          })}
          
          <div style="font-size: 0.85rem; color: var(--text-muted); padding: 10px 12px; border-left: 2px dashed var(--border-color); margin-left: 12px; line-height: 1.4;">
            <span style="font-size: 0.72rem; color: var(--text-muted); display: block; font-weight: 500; margin-bottom: 2px;">Post 4 • Coming Soon</span>
            4. Time Travel &amp; Memory: Persistence Engines, State Checkpointing, and Event Sourcing
          </div>
          <div style="font-size: 0.85rem; color: var(--text-muted); padding: 10px 12px; border-left: 2px dashed var(--border-color); margin-left: 12px; line-height: 1.4;">
            <span style="font-size: 0.72rem; color: var(--text-muted); display: block; font-weight: 500; margin-bottom: 2px;">Post 5 • Coming Soon</span>
            5. Hyper-Performance in Production: Context Engineering, Semantic Caching, and High-Throughput Adapt
          </div>
        </nav>
      </aside>

      <!-- Main Article Container -->
      <div class="series-main">
        {sortedPosts.map((post, index) => (
          <article id={`post-${post.data.postNumber}`} class="series-post product-article glass-card" style={`padding: 48px; background: var(--bg-secondary); border-radius: var(--border-radius-sm); border: 1px solid var(--border-color); ${index > 0 ? 'display: none;' : ''}`}>
            <div style="margin-bottom: 32px; border-bottom: 1px solid var(--border-color); padding-bottom: 24px;">
              <div style="font-size: 0.85rem; font-weight: 700; color: var(--accent-indigo); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1px;">SolidState Series • Post {post.data.postNumber}</div>
              <h1 style="font-size: 2.2rem; line-height: 1.25; margin-bottom: 12px; color: var(--text-primary);">{post.data.title}</h1>
              <div style="font-size: 1.05rem; font-weight: 600; color: var(--text-primary); margin-bottom: 4px;">Haranadh Gavara <span style="font-size: 0.85rem; color: var(--text-muted); font-weight: 500;">(AWS SA Pro TOGAF® PMP®)</span></div>
              <div style="font-size: 0.88rem; color: var(--text-secondary); margin-bottom: 16px; line-height: 1.4;">AI Systems Leader | Enterprise Architecture, Governed AI Platforms, Retrieval Systems, and Data Products</div>
              <div style="font-size: 0.9rem; color: var(--text-muted); display: flex; gap: 16px; align-items: center;">
                <span>{post.data.date}</span>
                <span>•</span>
                <span>{post.data.readTime}</span>
                <span>•</span>
                <span class="card-tag" style="margin: 0;">{post.data.tag}</span>
              </div>
            </div>

            <div style="font-size: 1rem; line-height: 1.75; color: var(--text-secondary);" set:html={post.body} />
          </article>
        ))}
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer style="margin-top: auto; border-top: 1px solid var(--border-color); padding: 40px 0 20px 0;">
    <div class="container" style="text-align: center;">
      <div class="social-icons" style="display: flex; justify-content: center; gap: 20px; margin-bottom: 16px;">
        <a href="https://www.linkedin.com/in/haranadhgavara/" target="_blank" rel="noopener noreferrer" style="color: var(--text-secondary); font-size: 1.25rem;"><i class="fab fa-linkedin-in"></i></a>
      </div>
      <p style="font-size: 0.88rem; color: var(--text-muted);">&copy; 2026 Haranadh Gavara. All rights reserved. Built with Astro.</p>
    </div>
  </footer>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const sidebarItems = document.querySelectorAll(".sidebar-item");
      const posts = document.querySelectorAll(".series-post");

      function showPost(postId) {
        posts.forEach(p => {
          if (p.id === postId) {
            p.style.display = "block";
            // Smooth fade-in effect
            p.style.opacity = 0;
            setTimeout(() => {
              p.style.transition = "opacity 0.25s ease-in-out";
              p.style.opacity = 1;
            }, 50);
          } else {
            p.style.display = "none";
          }
        });
        sidebarItems.forEach(item => {
          if (item.getAttribute("href") === "#" + postId) {
            item.classList.add("active");
          } else {
            item.classList.remove("active");
          }
        });
      }

      // Handle hash change routing
      window.addEventListener("hashchange", () => {
        const hash = window.location.hash.substring(1) || "post-1";
        if (document.getElementById(hash)) {
          showPost(hash);
        }
      });

      // Handle direct clicks (ensuring hash matches)
      sidebarItems.forEach(item => {
        item.addEventListener("click", (e) => {
          const hash = item.getAttribute("href").substring(1);
          if (document.getElementById(hash)) {
            showPost(hash);
          }
        });
      });

      // Initialize on load
      const initialHash = window.location.hash.substring(1) || "post-1";
      if (document.getElementById(initialHash)) {
        showPost(initialHash);
      }
    });
  </script>
</Layout>
