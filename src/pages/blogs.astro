---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { publicationsData } from '../data/publications';

// Query and sort general blogs for the client-side search/modal
const rawBlogs = await getCollection('blogs');
const blogsData = rawBlogs.map(blog => ({
  id: blog.id,
  title: blog.data.title,
  excerpt: blog.data.excerpt,
  date: blog.data.date,
  readTime: blog.data.readTime,
  tags: blog.data.tags,
  featured: blog.data.featured,
  content: blog.body
})).sort((a, b) => {
  if (a.featured && !b.featured) return -1;
  if (!a.featured && b.featured) return 1;
  return new Date(b.date).getTime() - new Date(a.date).getTime();
});
---

<Layout 
  title="Technical Blog | Haranadh Gavara | AI Systems, RAG & Enterprise Architecture" 
  description="Technical blog posts by Haranadh Gavara on advanced RAG, Entropy RAG (MaxEntRAG), Knowledge Graphs, Gaussian Processes, and Governed Enterprise AI Platforms."
  layoutMode="blog"
  backLink="/"
  backText="Return to Home"
>
  <!-- Main Essay Feed -->
  <div class="blogs-content-area">
    <div class="section-header text-center">
      <span class="section-label">Technical Blog</span>
      <h2 class="section-title">AI Systems &amp; Outcomes</h2>
      <p class="section-subtitle">
        An archive of operational perspectives on AI platforms, semantics-first data infrastructure, governance-led operating models, and enterprise value.
      </p>
    </div>

    <!-- Search Bar -->
    <div class="blog-search-bar">
      <i class="fas fa-search"></i>
      <input type="text" id="blog-search" placeholder="Search blog posts by tag, title, or keyword...">
    </div>

    <!-- Dynamic Blogs Grid (Loads everything on this dedicated subpage) -->
    <div class="blogs-grid" id="blogs-grid">
      <!-- Rendered dynamically by app.js -->
    </div>
  </div>

  <!-- Footer -->
  <footer style="margin-top: auto; border-top: 1px solid var(--border-color); padding: 40px 0 20px 0;">
    <div class="container" style="text-align: center;">
      <div class="social-icons" style="display: flex; justify-content: center; gap: 20px; margin-bottom: 16px;">
        <a href="https://www.linkedin.com/in/haranadhgavara/" target="_blank" rel="noopener noreferrer" style="color: var(--text-secondary); font-size: 1.25rem;"><i class="fab fa-linkedin-in"></i></a>
      </div>
      <p style="font-size: 0.88rem; color: var(--text-muted);">&copy; 2026 Haranadh Gavara. All rights reserved. Built with Astro.</p>
    </div>
  </footer>

  <!-- High-Fidelity Essay Reading Modal (Needed for viewing articles) -->
  <div class="modal" id="blog-modal" aria-hidden="true" role="dialog">
    <div class="modal-dialog">
      <div class="modal-header">
        <div class="modal-header-text">
          <h3 id="blog-modal-title">Optimizing AI Gateway Proxies</h3>
          <div class="modal-meta" id="blog-modal-meta">May 20, 2026 • 8 min read</div>
        </div>
        <button class="modal-close" aria-label="Close modal"><i class="fas fa-times"></i></button>
      </div>
      <div class="modal-body" id="blog-modal-body">
        <!-- Content injected by app.js -->
      </div>
    </div>
  </div>

  <!-- Inject the static datasets to satisfy the window object contracts in app.js -->
  <script is:inline define:vars={{ publicationsData, blogsData }}>
    window.publicationsData = publicationsData;
    window.blogsData = blogsData;
  </script>
</Layout>
